# Environment variables for local development (Docker compose service)
POSTGRES_DB=barber_saas
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_PORT=5432

# For local development, you can connect to the database using the following URL:
# DATABASE_URL="postgresql://admin:password123@localhost:5432/barber_saas?schema=public"

# Connect to Supabase via connection pooling (Production)
DATABASE_URL="postgresql://postgres.tzlrkxukvtbygckmkqan:YOUR-SUPABASE-PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations (Production)
DIRECT_URL="postgresql://postgres.tzlrkxukvtbygckmkqan:YOUR-SUPABASE-PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase Auth (Required for authentication)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Required for payment processing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For production
NEXT_PUBLIC_APP_URL=https://your-production-url.com

